<!DOCTYPE html>
<html>
<head>
  <title>Cotizador Petrocheck</title>

  <style>
    body {
      font-family: Arial;
      margin: 0;
      background: #f8f9fa;
    }

    header {
      background: #0a2c4a;
      color: white;
      padding: 20px;
      text-align: center;
    }

    .container {
      max-width: 1000px;
      margin: auto;
      padding: 20px;
    }

    .card {
      background: white;
      padding: 15px;
      margin-bottom: 10px;
      border-radius: 10px;
      border-left: 5px solid #0a2c4a;
    }

    .precios {
      font-size: 13px;
      color: #666;
    }

    select, button {
      width: 100%;
      padding: 12px;
      margin-top: 10px;
    }

    button {
      background: #0a2c4a;
      color: white;
      border: none;
      font-size: 16px;
    }

    .resultado {
      background: #e6f4ea;
      padding: 20px;
      margin-top: 20px;
      border-radius: 10px;
    }
  </style>
</head>

<body>

<header>
  <h2>Cotizador de Servicios Petrocheck</h2>
  <p>Certificando con calidad desde 1997</p>
</header>

<div class="container">

<h3>Selecciona los servicios:</h3>

<div id="servicios">

  <div class="card">
    <input type="checkbox" value="102|120|150">
    Hermeticidad en tanques
    <div class="precios">Normal: 150 | MasGas: 120 | Feria: 102</div>
  </div>

  <div class="card">
    <input type="checkbox" value="63.75|75|90">
    Hermeticidad en líneas
    <div class="precios">Normal: 90 | MasGas: 75 | Feria: 63.75</div>
  </div>

  <div class="card">
    <input type="checkbox" value="382.5|450|460">
    Limpieza de tanque
    <div class="precios">Normal: 460 | MasGas: 450 | Feria: 382.5</div>
  </div>

</div>

<h3>Ubicación:</h3>

<select id="ciudad">
  <option value="pichincha">Quito / Pichincha</option>
  <option value="ambato">Ambato</option>
  <option value="guayaquil">Guayaquil</option>
  <option value="cuenca">Cuenca</option>
  <option value="amazonia">Amazonía</option>
</select>

<button onclick="calcular()">Calcular Cotización</button>

<div class="resultado" id="resultado"></div>

<button onclick="whatsapp()">Enviar por WhatsApp</button>

</div>

<script>

// MAPEO CIUDAD → ZONA
function obtenerLogistica(ciudad) {

  if (ciudad == "pichincha") return 131; // zona 1
  if (ciudad == "ambato") return 131; // zona 2
  if (ciudad == "guayaquil") return 147; // zona 3
  if (ciudad == "cuenca") return 131; // zona 4
  if (ciudad == "amazonia") return 140; // zona 5

}

let mensaje = "";

function calcular() {

  let checks = document.querySelectorAll("#servicios input:checked");

  let totalFeria = 0;
  let totalNormal = 0;
  let totalMasgas = 0;

  checks.forEach(c => {
    let datos = c.value.split("|");
    totalFeria += parseFloat(datos[0]);
    totalMasgas += parseFloat(datos[1]);
    totalNormal += parseFloat(datos[2]);
  });

  let ciudad = document.getElementById("ciudad").value;
  let logistica = obtenerLogistica(ciudad);

  let totalFinal = totalFeria + logistica;

  mensaje =
    "COTIZACIÓN PETROCHECK%0A" +
    "Total Normal: $" + totalNormal + "%0A" +
    "Total MasGas: $" + totalMasgas + "%0A" +
    "Total Feria: $" + totalFeria + "%0A" +
    "Logística: $" + logistica + "%0A" +
    "TOTAL FINAL: $" + totalFinal;

  document.getElementById("resultado").innerHTML =
    "<b>Total Normal:</b> $" + totalNormal +
    "<br><b>Total MasGas:</b> $" + totalMasgas +
    "<br><b>Total Feria:</b> $" + totalFeria +
    "<br><b>Logística:</b> $" + logistica +
    "<br><hr><b>TOTAL FINAL:</b> $" + totalFinal;

}

function whatsapp() {
  let numero = "593XXXXXXXXX";
  window.open("https://wa.me/" + numero + "?text=" + mensaje);
}

</script>

</body>
</html>
